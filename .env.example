# ── Gemini AI (required) ──────────────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── Bot identity ──────────────────────────────────────────────────────────
BOT_DISPLAY_NAME=Protiviti AI Scribe

# ── Email delivery (optional) ─────────────────────────────────────────────
# Leave blank to skip email and only save files locally.
#
# Gmail setup:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_PASSWORD=  ← use an App Password, NOT your Google account password
#   Create one at: https://myaccount.google.com/apppasswords
#
# Office 365 / Outlook (Protiviti):
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_PASSWORD=  ← your Protiviti email password (or app password if MFA)
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
EMAIL_FROM=your-email@gmail.com

# Comma-separated list of recipients who get the MoM after each meeting
EMAIL_TO=recipient1@company.com,recipient2@company.com

# Organizer email — always receives the MoM regardless of EMAIL_TO
# Teams only shows the organizer's display name, not their email.
# Set this to the meeting organizer's actual email address.
ORGANIZER_EMAIL=organizer@company.com

# ── Teams chat posting + real speaker names via Microsoft Graph API (optional) ──
# Posts the MoM directly into the meeting chat (no browser automation), and
# fetches Teams' own transcript with REAL speaker names when transcription was
# turned on during the meeting (instead of generic "Speaker 1/2/...").
#
# Setup (one-time, ~5 minutes):
#   1. Go to https://portal.azure.com -> Microsoft Entra ID -> App registrations -> New registration
#   2. Name: "Protiviti AI Scribe", Supported accounts: Single tenant
#   3. Authentication tab -> Add platform -> "Mobile and desktop applications"
#      -> redirect URI: http://localhost
#      -> check "Allow public client flows" -> Save
#   4. API permissions -> Add a permission -> Microsoft Graph -> Delegated permissions:
#      Chat.ReadWrite, ChatMessage.Send, OnlineMeetings.Read,
#      OnlineMeetingTranscript.Read.All -> Add -> Grant admin consent
#   5. Copy the "Application (client) ID" and "Directory (tenant) ID" from the Overview page
#
# First run opens a browser once for you to sign in and consent; after that
# it refreshes silently using the cached token (graph_token_cache.bin).
# If you add OnlineMeetingTranscript.Read.All to an EXISTING app registration,
# the next run will open the browser once more to consent to the new scope.
#
# NOTE: this only works for meetings where YOU are the organizer.
# NOTE: real speaker names require clicking "Start transcription" (... menu ->
# Record and transcribe) during the meeting — Teams shows a banner to everyone
# when this happens. Without it, the bot falls back to its own live
# transcription with generic "Speaker 1/2/..." labels.
GRAPH_CLIENT_ID=your-azure-app-client-id
GRAPH_TENANT_ID=your-azure-tenant-id
